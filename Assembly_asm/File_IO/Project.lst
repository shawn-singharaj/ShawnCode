				; ParseTempsFromString
				; Takes the string from the read in file and converts into an array of integers based off the ASCII values of each character 
				; and broken up by a delimiter
				; Preconditions: String must be not empty, a string of number characters, and separated by delimiter
				; Posconditions: changes registers edi, esi, eax, ecx, ebx
				; Receives:
				;	[ebp + 8] = the resulting array to be returned, [ebp + 12] = the string to be converted to the array
				; Local vars: 
				;	[ebp - 1]: sign flag that increments when a '-' is encountered, makes the resulting integer a negative when stored
				;	[ebp - 5]: numint, the running value that is to be used to convert the ASCII value to the actual integer
				; Returns:
				;	[ebp + 12] = array of integers after conversion from string
 000000B7			ParseTempsFromString PROC
 000000B7  55				push	ebp
 000000B8  8B EC			mov		ebp, esp

 000000BA  8B 75 0C			mov		esi, [ebp + 12]		; input string
 000000BD  8B 7D 08			mov		edi, [ebp + 8]		; output array
 000000C0  B9 00000018			mov		ecx, TEMPS_PER_DAY

 000000C5  83 EC 06			sub		esp, 6
 000000C8  C6 45 FF 00			mov		BYTE PTR [ebp - 1], 0	; sign flag
 000000CC  C7 45 FB			mov		SDWORD PTR [ebp - 5], 0	; numint
	   00000000
 000000D3  C6 45 FA 00			mov		BYTE PTR [ebp - 6], 0 
					

 000000D7			_ConversionLoop:
 000000D7  AC				lodsb
 000000D8  3C 2C			cmp		al, DELIMITER				; compare current char to ','
 000000DA  74 35			je		_NewChar	
					
 000000DC  3C 0D			cmp		al, 13
 000000DE  74 28			je		_handleCr

 000000E0  3C 0A			cmp		al, 10
 000000E2  74 27			je		_handleLf

 000000E4  3C 2D			cmp		al, 45						; compare current char to '-'
 000000E6  74 1A			je		_negative
 000000E8  C6 45 FF 00			mov		BYTE PTR [ebp - 1], 0		; set sign flag to not negative
 000000EC			_continue:
 000000EC  2C 30			sub		al, 48						; find actual value of current char to integer
 000000EE  8A D8			mov		bl, al						; move that into bl
 000000F0  B8 0000000A			mov		eax, 10						; move 10 into eax to be multiplied
 000000F5  F7 65 FB			mul		SDWORD PTR [ebp - 5]		; multiply 10 by numint, store in eax
 000000F8  0F B6 DB			movzx	ebx, bl						; sign extend bl to ebx
 000000FB  03 C3			add		eax, ebx					; add number (eax) to converted ascii character (integer in ebx)
 000000FD  89 45 FB			mov		SDWORD PTR [ebp - 5], eax	; move eax to numint
 00000100  EB D5			jmp		_ConversionLoop

 00000102			_negative:
 00000102  FE 45 FF			inc		BYTE PTR [ebp - 1]
 00000105  AC				lodsb
 00000106  EB E4			jmp		_continue

 00000108			_handleCr:
 00000108  AC				lodsb
 00000109  EB CC			jmp		_ConversionLoop

 0000010B			_handleLf:
 0000010B  AC				lodsb
 0000010C  FE 45 FA			inc		BYTE PTR [ebp - 6]
 0000010F  EB C6			jmp		_ConversionLoop


 00000111			_NewChar:
 00000111  8B 45 FB			mov		eax, SDWORD PTR [ebp - 5]	; move numint into eax
 00000114  8A 5D FF			mov		bl, BYTE PTR [ebp - 1]
 00000117  80 FB 00			cmp		bl,	0						; compare sign flag to 0 (positive)
 0000011A  74 02			je		_alreadyPositive
					
 0000011C  F7 D8			neg		eax							; make numint into negative for array

 0000011E			_alreadyPositive:			
 0000011E  AB				stosd								; store into edi
 0000011F  C7 45 FB			mov		SDWORD PTR [ebp - 5], 0		; reset numint
	   00000000
 00000126  E2 AF			loop	_ConversionLoop

 00000128  83 C4 06			add		esp, 6
 0000012B  5D				pop		ebp
 0000012C  C2 000C			ret		12
 0000012F			ParseTempsFromString ENDP

				; WriteTempsReverse
				; Takes the array after being converted and outputs it to the terminal in reverse order with the delimiter between each number
				; Preconditions: Array must not be empty and made of (S)DWORD integers
				; Posconditions: changes registers edi, eax, ecx, ebx, edx
				; Receives:
				;	[ebp + 8] = the address of the array to be printed
				;	[ebp + 12] = line header string
				; Returns: None 
 0000012F			WriteTempsReverse PROC
 0000012F  55			    push    ebp
 00000130  8B EC		    mov     ebp, esp

 00000132  8B 7D 08		    mov     edi, [ebp + 8]            ; store array address into edi
 00000135  B9 00000018		    mov     ecx, TEMPS_PER_DAY        ; loop as many times as temperatures taken in that day
				  
 0000013A  B8 00000018			mov     eax, TEMPS_PER_DAY        
 0000013F  BB 00000004		    mov     ebx, 4
 00000144  F7 E3		    mul     ebx                        ; temps per day * 4 - 1 = last index of array
 00000146  83 E8 04		    sub     eax, 4                     
 00000149  03 F8		    add     edi, eax                   ; set edi address to last index

 0000014B  BB 00000000		    mov     ebx, 0                     ; index counter
 00000150  83 EC 04		    sub     esp, 4
 00000153  C7 45 FC		    mov     DWORD PTR [ebp - 4], 1     ; line counter
	   00000001

 0000015A  8B 55 0C		    mov     edx, [ebp + 12]
 0000015D  E8 00000000 E	    call    writeString
 00000162  8B 45 FC		    mov     eax, [ebp - 4]
 00000165  E8 00000000 E	    call    writeDec    

 0000016A			_printArray:                         
 0000016A  83 FB 18		    cmp     ebx, TEMPS_PER_DAY         ; check if we reached the end
 0000016D  74 14		    je      _newLine                   ; jump to _newLine if done printing

 0000016F  8B 07		    mov     eax, [edi]                 ; load temperature at index into eax
 00000171  E8 00000000 E	    call    writeInt                   ; print the temperature
				    mDisplayChar DELIMITER             ; print delimiter after the value
 00000176  B0 2C	     1		mov		al, DELIMITER
 00000178  E8 00000000 E     1		call	writeChar
 0000017D  83 EF 04		    sub     edi, 4                      ; move to the previous element in the array
 00000180  43			    inc     ebx                         ; increment counter
 00000181  EB 26		    jmp     _continuePrint              ; continue the loop

 00000183			_newLine:
 00000183  FF 45 FC		    inc     DWORD PTR [ebp - 4]        ; increment line counter
 00000186  E8 00000000 E	    call    crLf                       ; print newline
 0000018B  8B 55 0C		    mov     edx, [ebp + 12]            ; print header again
 0000018E  E8 00000000 E	    call    writeString
 00000193  8B 45 FC		    mov     eax, [ebp - 4]
 00000196  E8 00000000 E	    call    writeDec                   ; print the line number
				    mDisplayChar COLON                 ; print a colon
 0000019B  B0 3A	     1		mov		al, COLON
 0000019D  E8 00000000 E     1		call	writeChar
 000001A2  BB 00000000		    mov     ebx, 0                     ; reset array index counter
 000001A7  EB C1		    jmp     _printArray                ; continue printing next line

 000001A9			_continuePrint:
 000001A9  E2 BF		    loop    _printArray                ; loop based on the value in ecx

 000001AB  83 EC 04			sub		esp, 4
 000001AE  5D			    pop     ebp
 000001AF  C2 0008		    ret     8                          ; return and clean up the stack
 000001B2			WriteTempsReverse ENDP


				END main
