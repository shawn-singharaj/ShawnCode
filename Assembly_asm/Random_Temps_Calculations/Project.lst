				;-----------------------------------------------------------
				; Description: Finds the highest temperature for each day.
				;-----------------------------------------------------------
 00000134			findDailyHighs PROC
 00000134  55			    push ebp
 00000135  8B EC		    mov ebp, esp
 00000137  53			    push ebx
 00000138  52			    push edx
 00000139  51			    push ecx

 0000013A  8B 75 08		    mov esi, [ebp + 8]    ;pointer to tempArray
 0000013D  8B 7D 0C		    mov edi, [ebp + 12]   ;pointer to dailyHighs
 00000140  33 DB		    xor ebx, ebx          ;EBX = day counter (0 to DAYS_MEASURED - 1)

 00000142			highs_outer_loop:
 00000142  83 FB 0E		    cmp ebx, DAYS_MEASURED
 00000145  7D 37		    jge highs_done

				    ;day * TEMPS_PER_DAY
 00000147  8B CB		    mov ecx, ebx
 00000149  6B C9 0B		    imul ecx, TEMPS_PER_DAY   ;ECX = day base index
 0000014C  8B D1		    mov edx, ecx
 0000014E  C1 E2 02		    shl edx, 2                ;byte offset for the first element
 00000151  8B 04 16		    mov eax, [esi + edx]      ;initialize highest temperature for the day

				    ;inner loop
 00000154  BA 00000001		    mov edx, 1                ;inner loop counter j = 1
 00000159			highs_inner_loop:
 00000159  83 FA 0B		    cmp edx, TEMPS_PER_DAY
 0000015C  7D 15		    jge store_high
				    ;compute absolute index = (day * TEMPS_PER_DAY + j)
 0000015E  8B CB		    mov ecx, ebx
 00000160  6B C9 0B		    imul ecx, TEMPS_PER_DAY   ;ECX = day base index
 00000163  03 CA		    add ecx, edx              ;ECX = absolute index for current element
 00000165  C1 E1 02		    shl ecx, 2              ;convert index to byte offset
 00000168  3B 04 0E		    cmp eax, [esi + ecx]
 0000016B  7D 03		    jge skip_high_update
 0000016D  8B 04 0E		    mov eax, [esi + ecx]      ;update highest temperature
 00000170			skip_high_update:
 00000170  42			    inc edx
 00000171  EB E6		    jmp highs_inner_loop

 00000173			store_high:
				    ;store into dailyhighs
 00000173  8B CB		    mov ecx, ebx
 00000175  C1 E1 02		    shl ecx, 2
 00000178  89 04 0F		    mov [edi + ecx], eax
 0000017B  43			    inc ebx
 0000017C  EB C4		    jmp highs_outer_loop

 0000017E			highs_done:
 0000017E  59			    pop ecx
 0000017F  5A			    pop edx
 00000180  5B			    pop ebx
 00000181  5D			    pop ebp
 00000182  C2 0008		    ret 8
 00000185			findDailyHighs ENDP

				;-----------------------------------------------------------
