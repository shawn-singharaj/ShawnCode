 00000191  33 DB		    xor ebx, ebx          ;EBX = day counter (0 to DAYS_MEASURED - 1)

 00000193			lows_outer_loop:
 00000193  83 FB 0E		    cmp ebx, DAYS_MEASURED
 00000196  7D 37		    jge lows_done

				    ;compute base index for current day: day * TEMPS_PER_DAY
 00000198  8B CB		    mov ecx, ebx
 0000019A  6B C9 0B		    imul ecx, TEMPS_PER_DAY   ;ECX = day base index
 0000019D  8B D1		    mov edx, ecx
 0000019F  C1 E2 02		    shl edx, 2                ;byte offset for the first element
 000001A2  8B 04 16		    mov eax, [esi + edx]      ;initialize lowest temperature for the day

				    ;inner loop: iterate through remaining temperatures for the day
 000001A5  BA 00000001		    mov edx, 1                ;inner loop counter j = 1
 000001AA			lows_inner_loop:
 000001AA  83 FA 0B		    cmp edx, TEMPS_PER_DAY
 000001AD  7D 15		    jge store_low
				    ;day * TEMPS_PER_DAY + j
 000001AF  8B CB		    mov ecx, ebx
 000001B1  6B C9 0B		    imul ecx, TEMPS_PER_DAY   ;ECX = day base index
 000001B4  03 CA		    add ecx, edx              ;ECX = absolute index for current element
 000001B6  C1 E1 02		    shl ecx, 2                ;convert index to byte offset
 000001B9  3B 04 0E		    cmp eax, [esi + ecx]
 000001BC  7E 03		    jle skip_low_update
 000001BE  8B 04 0E		    mov eax, [esi + ecx]     
 000001C1			skip_low_update:
 000001C1  42			    inc edx
 000001C2  EB E6		    jmp lows_inner_loop

 000001C4			store_low:
