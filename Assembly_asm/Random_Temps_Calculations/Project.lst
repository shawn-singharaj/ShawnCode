 000001C6  C1 E1 02		    shl ecx, 2
 000001C9  89 04 0F		    mov [edi + ecx], eax
 000001CC  43			    inc ebx
 000001CD  EB C4		    jmp lows_outer_loop

 000001CF			lows_done:
 000001CF  59			    pop ecx
 000001D0  5A			    pop edx
 000001D1  5B			    pop ebx
 000001D2  5D			    pop ebp
