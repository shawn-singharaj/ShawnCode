 00000000			main PROC
				; introduce self
 00000000  BA 00000000 R		mov		edx, OFFSET intro_1
 00000005  E8 00000000 E		call	WriteString
 0000000A  E8 00000000 E		call	CrLf
 0000000F  BA 000001F2 R		mov		edx, OFFSET extra_1
 00000014  E8 00000000 E		call	WriteString
 00000019  E8 00000000 E		call	CrLf

				; get user name
 0000001E  BA 0000002B R		mov		edx, OFFSET prompt_1
 00000023  E8 00000000 E		call	WriteString
 00000028  BA 00000051 R		mov		edx, OFFSET user_name
 0000002D  B9 00000020			mov		ecx, 32
 00000032  E8 00000000 E		call	ReadString 
 00000037  E8 00000000 E		call	CrLf
 0000003C  BA 0000003E R		mov		edx, OFFSET intro_2
 00000041  E8 00000000 E		call	WriteString
 00000046  BA 00000051 R		mov		edx, OFFSET user_name
 0000004B  E8 00000000 E		call	WriteString
 00000050  E8 00000000 E		call	CrLf
 00000055  BA 00000072 R		mov		edx, OFFSET prompt_2
 0000005A  E8 00000000 E		call	WriteString
 0000005F  E8 00000000 E		call	CrLf

					; get number of temperatures the user wants to input
 00000064  BA 000000E7 R		mov		edx, OFFSET loop_prompt
 00000069  E8 00000000 E		call	WriteString
 0000006E  E8 00000000 E		call	readInt
 00000073  A3 00000120 R		mov		loop_limit, eax
 00000078  E8 00000000 E		call	CrLf
 0000007D  8B 1D 00000120 R		mov		ebx, loop_limit	; store into ebx to compare to current iteration
					

				; loop 7 times to get user inputs
 00000083			_userInput:
 00000083  39 1D 0000011C R		cmp		loop_count,  ebx ; loop until loop_count equals to loop_limit
 00000089  0F 83 0000009D		jae		_showResults

					; prompt user input
 0000008F  BA 000000BB R		mov		edx, OFFSET prompt_temp
 00000094  E8 00000000 E		call	WriteString
 00000099  E8 00000000 E		call	ReadInt


 0000009E  83 F8 E2			cmp		eax, COLD	; if input is less than -30, jump  to loop again
 000000A1  7C 07			jl		_tooLow
 000000A3  83 F8 32			cmp		eax, HOT	; if input is greater than 50, jump to loop again
 000000A6  7F 13			jg		_tooHigh
 000000A8  EB 22			jmp		_validInput

				; if user input is too low
 000000AA			_tooLow:
 000000AA  BA 000000C9 R		mov		edx, OFFSET too_cold
 000000AF  E8 00000000 E		call	WriteString
 000000B4  E8 00000000 E		call	CrLf
 000000B9  EB C8			jmp		_userInput

				; if user input is too high
 000000BB			_tooHigh:
 000000BB  BA 000000DD R		mov		edx, OFFSET too_hot
 000000C0  E8 00000000 E		call	WriteString
 000000C5  E8 00000000 E		call	CrLf
 000000CA  EB B7			jmp		_userInput

				; when input is valid
 000000CC			_validInput:
 000000CC  01 05 0000013C R		add		average, eax	 ; add current value to average
 000000D2  FF 05 0000011C R		inc		loop_count		 ; increment looop count
 000000D8  3B 05 00000128 R		cmp		eax, min_temp
 000000DE  7F 07			jg		_maxTemp		 ; jump to max temp if it isnt lowest
					
 000000E0			_minTemp:
 000000E0  A3 00000128 R		mov		min_temp, eax
 000000E5  EB 0D			jmp		_cold			; jump past max temp

 000000E7			_maxTemp:
 000000E7  3B 05 00000124 R		cmp		eax, max_temp
 000000ED  7C 05			jl		_cold			; jump past if not max temp
 000000EF  A3 00000124 R		mov		max_temp, eax

 000000F4			_cold:
 000000F4  83 F8 00			cmp		eax, 0
 000000F7  79 08			jns		_cool			; jump to cool if not cold
 000000F9  FF 05 0000012C R		inc		num_cold
 000000FF  EB 82			jmp		_userInput

 00000101			_cool:
 00000101  83 F8 0F			cmp		eax, 15
 00000104  7F 0B			jg		_warm			; jump to warm if not cool
 00000106  FF 05 00000130 R		inc		num_cool
 0000010C  E9 FFFFFF72			jmp		_userInput

 00000111			_warm:
 00000111  83 F8 32			cmp		eax, HOT
 00000114  7F 0B			jg		_hot			; jump to hot if not warm
 00000116  FF 05 00000138 R		inc		num_warm
 0000011C  E9 FFFFFF62			jmp		_userInput

 00000121			_hot:
 00000121  FF 05 00000134 R		inc		num_hot
 00000127  E9 FFFFFF57			jmp		_userInput		; must be hot, so jump back to next input

 0000012C			_showResults:
					; find average
 0000012C  33 D2			xor		edx, edx
 0000012E  A1 0000013C R		mov		eax, average
 00000133  F7 FB			idiv	ebx
 00000135  A3 0000013C R		mov		average, eax

					; display coldest, hottest, and average temps
 0000013A  E8 00000000 E		call	CrLf
 0000013F  BA 00000140 R		mov		edx, OFFSET coldest_day
 00000144  E8 00000000 E		call	WriteString
 00000149  A1 00000128 R		mov		eax, min_temp
 0000014E  E8 00000000 E		call	WriteInt
 00000153  E8 00000000 E		call	CrLf
 00000158  BA 0000015E R		mov		edx, OFFSET hottest_day
 0000015D  E8 00000000 E		call	WriteString
 00000162  A1 00000124 R		mov		eax, max_temp
 00000167  E8 00000000 E		call	WriteInt
 0000016C  E8 00000000 E		call	CrLf
 00000171  BA 0000017C R		mov		edx, OFFSET avg_temp
 00000176  E8 00000000 E		call	WriteString
 0000017B  A1 0000013C R		mov		eax, average
 00000180  E8 00000000 E		call	WriteInt
 00000185  E8 00000000 E		call	CrLf

					; display number of days per category
 0000018A  BA 00000192 R		mov		edx, OFFSET cold_res
 0000018F  E8 00000000 E		call	WriteString
 00000194  A1 0000012C R		mov		eax, num_cold
 00000199  E8 00000000 E		call	WriteDec
 0000019E  E8 00000000 E		call	CrLf
 000001A3  BA 000001A8 R		mov		edx, OFFSET cool_res
 000001A8  E8 00000000 E		call	WriteString
 000001AD  A1 00000130 R		mov		eax, num_cool
 000001B2  E8 00000000 E		call	WriteDec
 000001B7  E8 00000000 E		call	CrLf
 000001BC  BA 000001BE R		mov		edx, OFFSET warm_res
 000001C1  E8 00000000 E		call	WriteString
 000001C6  A1 00000138 R		mov		eax, num_warm
 000001CB  E8 00000000 E		call	WriteDec
 000001D0  E8 00000000 E		call	CrLf
 000001D5  BA 000001D4 R		mov		edx, OFFSET hot_res
 000001DA  E8 00000000 E		call	WriteString
 000001DF  A1 00000134 R		mov		eax, num_hot
 000001E4  E8 00000000 E		call	WriteDec
 000001E9  E8 00000000 E		call	CrLf

					; goodbye
 000001EE  BA 000001E9 R		mov		edx, OFFSET goodbye
 000001F3  E8 00000000 E		call	WriteString
 000001F8  BA 00000051 R		mov		edx, OFFSET	user_name
 000001FD  E8 00000000 E		call	WriteString


					Invoke ExitProcess,0	; exit to operating system
